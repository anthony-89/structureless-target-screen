+    a2 = f"{-15.2:10.4f}{-1.65:10.4f}{15.2:10.4f} O   0  0"
+    return ("mol\n  prog\ncomment\n"
+            "  2  1  0  0  0  0  0  0  0  0999 V2000\n"
+            f"{a1}\n{a2}\n  1  2  1  0\nM  END\n$$$$\n")
